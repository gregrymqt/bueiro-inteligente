<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  app:cardCornerRadius="12dp"
  app:cardElevation="8dp"
  android:layout_margin="8dp"
>
  <LinearLayout
    android:id="@+id/ll_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFCDD2"
  >
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
    >
      <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="⚠️ Alerta de Bueiro"
        android:textColor="#333333"
        android:textSize="18sp"
        android:textStyle="bold"
      />
      <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#555555"
        android:contentDescription="Fechar card"
      />
    </LinearLayout>
    <TextView
      android:id="@+id/tv_drain_id"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:textColor="#444444"
      android:textSize="16sp"
      tools:text="ID: 154B"
    />
    <TextView
      android:id="@+id/tv_last_update"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:textColor="#666666"
      android:textSize="14sp"
      tools:text="Atualizado às: 10:30"
    />
    <TextView
      android:id="@+id/tv_obstruction"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:textColor="#333333"
      android:textStyle="bold"
      tools:text="Nível de Obstrução: 85%"
    />
    <ProgressBar
      android:id="@+id/progress_obstruction"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:max="100"
      tools:progress="85"
    />
    <Button
      android:id="@+id/btn_map"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:text="Ver no Mapa"
      android:textColor="#FFFFFF"
      android:backgroundTint="#1976D2"
    />
  </LinearLayout>
</androidx.cardview.widget.CardView>
